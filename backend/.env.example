# Application
DEBUG=True
ENVIRONMENT=development

# Database
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/crochet_db
DATABASE_NAME=crochet_db

# JWT Authentication
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Integration
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key
CLAUDE_API_KEY=your-claude-key
AI_PROVIDER=openai  # options: openai, gemini, claude

# CORS
FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=http://localhost:5173

# Firebase
FIREBASE_API_KEY=your-firebase-key
FIREBASE_AUTH_DOMAIN=your-firebase-domain
FIREBASE_DATABASE_URL=your-firebase-db-url
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-storage-bucket

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
